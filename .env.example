SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SENDGRID_API_KEY=SG.YOUR_SENDGRID_API_KEY

# Required for guardian set upgrade VAA retrieval from Ethereum transaction calldata.
# Obtain a free API key at https://etherscan.io/myapikey
# Without this, the rotation alert falls back to Wormholescan (which may not have the VAA indexed).
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
